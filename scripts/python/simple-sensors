import time
import subprocess
import re
import argparse
import os

MINIMAL = ["BAT0", "dell_ddv-virtual-0"]

# ANSI colors
YELLOW = "\033[33m"
BLUE = "\033[34m"
RED = "\033[31m"
GREEN = "\033[32m"
RESET = "\033[0m" #Reset default to color

def get_sensors_data(filter_keyword=""):
    try:
        # Run the 'sensors' command and capture the text output
        result = subprocess.run(['sensors'], capture_output=True, text=True, check=True)
        raw_output = result.stdout
    except subprocess.CalledProcessError:
        return "Error: lm-sensors is not installed or failed to run."

    # Split output into sections by hardware chip (separated by double newlines)
    sections = raw_output.strip().split('\n\n')
    
    parsed_data = {}

    for section in sections:
        lines = section.split('\n')
        chip_name = lines[0] # The first line is always the chip name
        
        # Skip this chip if it doesn't match our filter
        if filter_keyword and filter_keyword.lower() not in chip_name.lower():
            continue
            
        parsed_data[chip_name] = []
        
        # Regex to find a label and a numerical value (handles temps, RPM, and Volts)
        # Matches: "Core 0:   +45.0°C" or "fan1:   1200 RPM"
        pattern = re.compile(r'^(.*?):\s+([+-]?\d+\.?\d*)')
        
        for line in lines[1:]:
            match = pattern.search(line)
            if match:
                label = match.group(1).strip()
                value = match.group(2).strip()
                parsed_data[chip_name].append(f"{label}: {value}")

    return parsed_data

def print_sensor_data(sensor_list: list):
    print(f"{GREEN}Filtered output from sensors:{RESET}")

    for sensor in sensor_list:
        data = get_sensors_data(sensor)
        if not data:
            print(f"{RED}Sensor {sensor} not found.{RESET}")
        else:
            for chip, features in data.items():
                print(f"{YELLOW}\n--- {chip} ---{RESET}")
                for f in features:
                    print(f)

def run_sensors(sensor_list: list, refresh: bool = False):
    if refresh:
        try:
            while True:
                os.system("clear")
                print_sensor_data(sensor_list)
                time.sleep(1.5) 
        except KeyboardInterrupt:
            print(f"\n{GREEN}Quitting simple-sensors{RESET}")
    else:
        print_sensor_data(sensor_list)
        

def main():
    parser = argparse.ArgumentParser(description="Refined output from lm-sensors")
    parser.add_argument("-r", "--refresh", action="store_true", help="Automatically refresh every second")
    parser.add_argument("-m", "--minimal", action="store_true", help="Run a minimal default")

    args = parser.parse_args()

    if args.minimal:
        run_sensors(MINIMAL, args.refresh)
    else:
        keyword = input("Enter a keyword to filter (e.g., 'nvme', 'coretemp'): ")
        run_sensors([keyword], args.refresh)

if __name__ == "__main__":
    main()

